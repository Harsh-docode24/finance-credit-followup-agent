# ============================================================
# Finance Credit Follow-Up Email Agent - Environment Config
# ============================================================
# Copy this file to .env and fill in your actual values.

# ── LLM Configuration ──────────────────────────────────────
# Provider: "gemini" (default) or "groq" (free fallback)
LLM_PROVIDER=gemini

# Google Gemini API Key (get FREE from https://aistudio.google.com/app/apikey)
# Steps: 1. Sign in with Google  2. Click "Create API Key"  3. Copy the key
GOOGLE_API_KEY=your_google_api_key_here

# Model to use (default: gemini-2.0-flash)
LLM_MODEL=gemini-2.0-flash

# (Optional) Groq API Key — fallback if Gemini quota is exhausted
# Get FREE from https://console.groq.com/keys
# Set LLM_PROVIDER=groq and LLM_MODEL=llama-3.3-70b-versatile to use
GROQ_API_KEY=

# ── Email Configuration (Optional - Dry-run mode by default) ─
# Set EMAIL_MODE to "smtp" to actually send emails, or "dry_run" for logging only
EMAIL_MODE=dry_run

# SMTP Settings (only needed if EMAIL_MODE=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SENDER_EMAIL=your_email@gmail.com
SENDER_NAME=Finance Department

# ── Database Configuration ─────────────────────────────────
# SQLite database path (auto-created, local-only, excluded from Git)
DATABASE_URL=sqlite:///data/audit_trail.db

# ── Application Settings ───────────────────────────────────
# Company name used in email templates
COMPANY_NAME=Acme Corp
COMPANY_PHONE=+91-9876543210
PAYMENT_LINK_BASE=https://pay.acmecorp.com/invoice/

# ── Security ───────────────────────────────────────────────
# Maximum emails per run (safety cap)
MAX_EMAILS_PER_RUN=50

# Enable PII masking in console/log output
MASK_PII_IN_LOGS=true
